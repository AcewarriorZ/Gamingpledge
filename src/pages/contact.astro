---
import Base from "@/layouts/Base.astro";

const contactEmail = "contact@gamingpledge.com";

const enquiryTypes = [
  {
    value: "review-code",
    label: "Review code / PR enquiry",
  },
  {
    value: "game-recommendation",
    label: "Game recommendation",
  },
  {
    value: "correction-feedback",
    label: "Correction or feedback",
  },
  {
    value: "collaboration",
    label: "Collaboration idea",
  },
  {
    value: "general",
    label: "General message",
  },
];
---

<Base>
  <section class="section py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-4xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary">
          Contact Gaming Pledge
        </p>

        <h1 class="text-5xl font-bold tracking-tight md:text-6xl">
          Review enquiries, recommendations and gaming messages.
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-text-light md:text-xl">
          Use the form below for review codes, indie game coverage, retro game recommendations,
          corrections, collaboration ideas or general messages.
        </p>
      </div>

      <div class="mx-auto mt-14 grid max-w-6xl gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <!-- Contact info -->
        <aside class="space-y-6">
          <div class="rounded-3xl bg-dark px-6 py-8 text-white md:px-8">
            <p class="text-sm font-semibold uppercase tracking-wide text-white/55">
              Best for
            </p>

            <h2 class="mt-3 text-3xl font-bold tracking-tight">
              Games with a strong hook, atmosphere or story.
            </h2>

            <p class="mt-5 leading-relaxed text-white/75">
              Gaming Pledge is especially interested in retro-inspired games, unusual indie titles,
              PS2-era favourites, forgotten licensed games and titles with something interesting to say.
            </p>
          </div>

          <div class="rounded-3xl border border-border bg-body p-7">
            <h2 class="text-2xl font-bold">Before you send</h2>

            <div class="mt-4 space-y-4 text-text-light">
              <p>
                Submitting a game or message does not guarantee coverage. Gaming Pledge is a personal blog,
                so coverage depends on interest, availability and fit.
              </p>

              <p>
                For review requests, please include the game name, platform, release date and any useful links.
              </p>
            </div>
          </div>

          <div class="rounded-3xl border border-border bg-body p-7">
            <h2 class="text-2xl font-bold">Prefer email?</h2>

            <p class="mt-3 leading-relaxed text-text-light">
              You can also contact Gaming Pledge directly at:
            </p>

            <a
              href={`mailto:${contactEmail}`}
              class="mt-4 inline-flex font-bold text-primary transition hover:opacity-80"
            >
              {contactEmail}
            </a>
          </div>
        </aside>

        <!-- Form -->
        <div class="rounded-3xl border border-border bg-body p-6 shadow-sm md:p-8">
          <form
            name="gaming-pledge-contact"
            method="POST"
            data-netlify="true"
            action="/contact/success"
            class="space-y-6"
          >
            <input type="hidden" name="form-name" value="gaming-pledge-contact" />

            <div>
              <label for="enquiry-type" class="form-label">
                What are you getting in touch about?
              </label>

              <select
                id="enquiry-type"
                name="enquiryType"
                class="form-field"
                required
              >
                <option value="">Select an enquiry type</option>

                {enquiryTypes.map((type) => (
                  <option value={type.value}>{type.label}</option>
                ))}
              </select>

              <p id="enquiry-helper" class="mt-2 text-sm text-text-light">
                Choose the option that best matches your message.
              </p>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label for="name" class="form-label">
                  Your name
                </label>

                <input
                  id="name"
                  name="name"
                  type="text"
                  class="form-field"
                  placeholder="Your name"
                  required
                />
              </div>

              <div>
                <label for="email" class="form-label">
                  Email address
                </label>

                <input
                  id="email"
                  name="email"
                  type="email"
                  class="form-field"
                  placeholder="you@example.com"
                  required
                />
              </div>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label for="game-title" class="form-label">
                  Game title
                </label>

                <input
                  id="game-title"
                  name="gameTitle"
                  type="text"
                  class="form-field"
                  placeholder="Optional, but useful"
                />
              </div>

              <div>
                <label for="platform" class="form-label">
                  Platform
                </label>

                <input
                  id="platform"
                  name="platform"
                  type="text"
                  class="form-field"
                  placeholder="PS2, Steam, Switch, Xbox, etc."
                />
              </div>
            </div>

            <div>
              <label for="links" class="form-label">
                Useful links
              </label>

              <input
                id="links"
                name="links"
                type="text"
                class="form-field"
                placeholder="Steam page, press kit, trailer, website, etc."
              />
            </div>

            <div>
              <label for="message" class="form-label">
                Message
              </label>

              <textarea
                id="message"
                name="message"
                rows="7"
                class="form-field resize-y"
                placeholder="Tell me what you are sending over and why it may be a good fit for Gaming Pledge."
                required
              ></textarea>
            </div>

            <button
              id="submit-button"
              type="submit"
              class="inline-flex min-h-[48px] w-full items-center justify-center rounded-full bg-primary px-6 py-3 font-bold text-white transition hover:opacity-90 md:w-auto"
            >
              <span id="submit-button-text">Send Message</span>
            </button>

            <p class="text-sm leading-relaxed text-text-light">
              This form is set up for static hosting with Netlify Forms. If the site is hosted elsewhere,
              we can connect it to Formspree, Basin, Cloudflare or a custom handler later.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .form-label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 700;
    color: var(--color-text, #111111);
  }

  .form-field {
    width: 100%;
    border: 1px solid rgba(15, 23, 42, 0.14);
    border-radius: 1rem;
    background: white;
    padding: 0.9rem 1rem;
    color: inherit;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .form-field:focus {
    border-color: var(--color-primary, #121212);
    box-shadow: 0 0 0 4px rgba(18, 18, 18, 0.08);
  }
</style>

<script is:inline>
  function initDynamicContactButton() {
    const enquirySelect = document.querySelector("#enquiry-type");
    const helperText = document.querySelector("#enquiry-helper");
    const submitButtonText = document.querySelector("#submit-button-text");

    if (!enquirySelect || !helperText || !submitButtonText) {
      return;
    }

    const buttonLabels = {
      "review-code": "Submit Review Request",
      "game-recommendation": "Send Recommendation",
      "correction-feedback": "Send Feedback",
      "collaboration": "Send Collaboration Idea",
      "general": "Send Message",
    };

    const helperMessages = {
      "review-code":
        "Include the game name, platform, release date, review code details and any useful links.",
      "game-recommendation":
        "Tell me what the game is, where to play it and why you think it deserves coverage.",
      "correction-feedback":
        "Send over the article link and what needs correcting or clarifying.",
      "collaboration":
        "Share the idea, who is involved and what you have in mind.",
      "general":
        "Send any general Gaming Pledge message, question or note here.",
    };

    enquirySelect.addEventListener("change", function () {
      const selectedValue = enquirySelect.value;

      submitButtonText.textContent =
        buttonLabels[selectedValue] || "Send Message";

      helperText.textContent =
        helperMessages[selectedValue] ||
        "Choose the option that best matches your message.";
    });
  }

  document.addEventListener("DOMContentLoaded", initDynamicContactButton);
  document.addEventListener("astro:page-load", initDynamicContactButton);
</script>