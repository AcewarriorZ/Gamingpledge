{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "meta_title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "categories": {
      "default": [
        "others"
      ],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authors": {
      "default": [
        "Admin"
      ],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "default": [
        "others"
      ],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draft": {
      "type": "boolean"
    },
    "score": {
      "type": "string"
    },
    "scoreLabel": {
      "type": "string"
    },
    "verdict": {
      "type": "string"
    },
    "bestFor": {
      "type": "string"
    },
    "strongestPoint": {
      "type": "string"
    },
    "weakestPoint": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}